<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground"
    android:padding="16dp">

    <!-- 顶部工具栏：正则输入 + 修饰符 + 编码 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top">

        <!-- 正则表达式输入框 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_regex"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Regular Expression"
            app:boxBackgroundColor="?attr/colorSurface"
            app:boxStrokeColor="?attr/colorPrimary"
            app:hintTextColor="?attr/colorPrimary"
            app:boxCornerRadiusTopStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusBottomEnd="8dp"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_regex"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurface"
                android:inputType="textNoSuggestions"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 修饰符按钮 (Flags) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_modifiers"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:text="Flags"
            android:textColor="?attr/colorOnSecondaryContainer"
            android:textSize="12sp"
            app:backgroundTint="?attr/colorSecondaryContainer"
            app:cornerRadius="8dp"
            app:rippleColor="?attr/colorControlHighlight"
            style="@style/Widget.Material3.Button.TonalButton"/>

        <!-- 编码选择器 -->
        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/sp_encoding"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_spinner_selector"
            android:paddingHorizontal="12dp"
            android:spinnerMode="dropdown"/>
    </LinearLayout>

    <!-- 状态与错误提示 -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="4dp"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:text="Ready"
        android:textColor="?attr/colorOutline"/>

    <!-- 待匹配文本输入 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Test String"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:boxBackgroundColor="?attr/colorSurface"
        app:boxStrokeColor="?attr/colorOutline"
        app:boxCornerRadiusTopStart="8dp"
        app:boxCornerRadiusTopEnd="8dp"
        app:boxCornerRadiusBottomStart="8dp"
        app:boxCornerRadiusBottomEnd="8dp"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="2"
            android:maxLines="4"
            android:gravity="top|start"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurface"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 匹配结果展示区 (绿色块区域) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Match Results"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:textColor="?attr/colorOutline"/>

        <TextView
            android:id="@+id/tv_match_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="No matches found."/>
    </LinearLayout>

    <!-- 铁路图可视化区域 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Structure (Railroad Diagram)"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="4dp"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="?attr/colorOutline">

        <!-- 双向滚动容器 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true">

                <android.studio.zero.regular.expression.preview.railroad.RailroadDiagramView
                    android:id="@+id/railroad_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="20dp"/>

            </HorizontalScrollView>
        </ScrollView>
            
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>