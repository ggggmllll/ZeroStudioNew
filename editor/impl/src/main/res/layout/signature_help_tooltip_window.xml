<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/signature_help_signature_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="4dp"
        android:textStyle="bold"
        android:textSize="14sp" />

    <ScrollView
        android:id="@+id/signature_help_scroll_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxHeight="120dp">
        
        <TextView
            android:id="@+id/signature_help_documentation_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="4dp"
            android:textSize="12sp" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/signature_help_navigation_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical|end"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:id="@+id/signature_help_previous"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_media_previous" />

        <TextView
            android:id="@+id/signature_help_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:text="1/1" />

        <ImageView
            android:id="@+id/signature_help_next"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_media_next" />
    </LinearLayout>
</LinearLayout>