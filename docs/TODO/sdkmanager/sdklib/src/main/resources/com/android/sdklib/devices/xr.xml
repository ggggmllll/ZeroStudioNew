<?xml version="1.0"?>
<d:devices
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:d="http://schemas.android.com/sdk/devices/8">
    <d:device>
        <d:name>XR Headset</d:name>
        <d:id>xr_headset_device</d:id>
        <d:manufacturer>Google</d:manufacturer>
        <d:playstore-enabled>true</d:playstore-enabled>
        <d:hardware>
            <d:screen>
                <d:screen-size>normal</d:screen-size>
                <d:diagonal-length>6.0</d:diagonal-length>
                <d:pixel-density>xhdpi</d:pixel-density>
                <d:screen-ratio>notlong</d:screen-ratio>
                <d:dimensions>
                    <!-- X and Y dimensions are temporarily reversed to workaround b/369630150 -->
                    <d:x-dimension>2560</d:x-dimension>
                    <d:y-dimension>2558</d:y-dimension>
                </d:dimensions>
                <d:xdpi>240</d:xdpi>
                <d:ydpi>240</d:ydpi>
                <d:touch>
                    <d:multitouch>jazz-hands</d:multitouch>
                    <d:mechanism>finger</d:mechanism>
                    <d:screen-type>notouch</d:screen-type>
                </d:touch>
            </d:screen>
            <d:networking>
                Wifi
                Bluetooth
                NFC
            </d:networking>
            <d:sensors>
                Accelerometer
                Barometer
                Compass
                GPS
                Gyroscope
                LightSensor
                ProximitySensor
                StepCounter
                StepDetector
            </d:sensors>
            <d:mic>true</d:mic>
            <d:camera>
                <d:location>front</d:location>
                <d:autofocus>false</d:autofocus>
                <d:flash>false</d:flash>
            </d:camera>
            <d:keyboard>qwerty</d:keyboard>
            <d:nav>trackball</d:nav>
            <d:ram unit="GiB">4</d:ram>
            <d:buttons>soft</d:buttons>
            <d:internal-storage unit="GiB">10</d:internal-storage>
            <d:removable-storage unit="MiB">0</d:removable-storage>
            <d:cpu>Generic CPU</d:cpu>
            <d:gpu>Generic GPU</d:gpu>
            <d:abi>
                armeabi
                armeabi-v7a
                arm64-v8a
                x86
                x86_64
                mips
                mips64
            </d:abi>
            <d:dock> </d:dock>
            <d:power-type>battery</d:power-type>
        </d:hardware>
        <d:software>
            <d:api-level>34</d:api-level>
            <d:live-wallpaper-support>true</d:live-wallpaper-support>
            <d:bluetooth-profiles> </d:bluetooth-profiles>
            <d:gl-version>3.2</d:gl-version>
            <d:gl-extensions/>
            <d:status-bar>true</d:status-bar>
        </d:software>
        <d:state name="Landscape" default="true">
            <d:description>The device in landscape view</d:description>
            <d:screen-orientation>land</d:screen-orientation>
            <d:keyboard-state>keyshidden</d:keyboard-state>
            <d:nav-state>nonav</d:nav-state>
        </d:state>
        <d:tag-id>android-xr</d:tag-id>
    </d:device>

    <d:device>
        <d:name>AI Glasses</d:name>
        <d:id>ai_glasses_device</d:id>
        <d:manufacturer>Google</d:manufacturer>
        <d:hardware>
            <d:screen>
                <d:screen-size>normal</d:screen-size>
                <d:diagonal-length>1.0</d:diagonal-length>
                <d:pixel-density>mdpi</d:pixel-density>
                <d:screen-ratio>notlong</d:screen-ratio>
                <d:dimensions>
                    <d:x-dimension>450</d:x-dimension>
                    <d:y-dimension>450</d:y-dimension>
                </d:dimensions>
                <d:xdpi>160</d:xdpi>
                <d:ydpi>160</d:ydpi>
                <d:touch>
                    <d:multitouch>jazz-hands</d:multitouch>
                    <d:mechanism>finger</d:mechanism>
                    <d:screen-type>notouch</d:screen-type>
                </d:touch>
            </d:screen>
            <d:touchpad>
                <d:width>1542</d:width>
                <d:height>297</d:height>
            </d:touchpad>
            <d:networking>
                Wifi
                Bluetooth
            </d:networking>
            <d:sensors>
                Accelerometer
                Compass
                Gyroscope
                LightSensor
                ProximitySensor
            </d:sensors>
            <d:mic>true</d:mic>
            <d:camera>
                <d:location>back</d:location>
                <d:sensor-orientation>0</d:sensor-orientation>
                <d:autofocus>false</d:autofocus>
                <d:flash>false</d:flash>
            </d:camera>
            <d:keyboard>nokeys</d:keyboard>
            <d:nav>nonav</d:nav>
            <d:ram unit="GiB">4</d:ram>
            <d:buttons>soft</d:buttons>
            <d:internal-storage unit="GiB">10</d:internal-storage>
            <d:removable-storage unit="MiB">0</d:removable-storage>
            <d:cpu>Generic CPU</d:cpu>
            <d:gpu>Generic GPU</d:gpu>
            <d:abi>
                armeabi
                armeabi-v7a
                arm64-v8a
            </d:abi>
            <d:dock> </d:dock>
            <d:power-type>battery</d:power-type>
        </d:hardware>
        <d:software>
            <d:api-level>36</d:api-level>
            <d:live-wallpaper-support>false</d:live-wallpaper-support>
            <d:bluetooth-profiles> </d:bluetooth-profiles>
            <d:gl-version>3.2</d:gl-version>
            <d:gl-extensions/>
            <d:status-bar>false</d:status-bar>
        </d:software>
        <d:state name="Landscape" default="true">
            <d:description>The device in landscape view</d:description>
            <d:screen-orientation>land</d:screen-orientation>
            <d:keyboard-state>keyshidden</d:keyboard-state>
            <d:nav-state>nonav</d:nav-state>
        </d:state>
        <d:tag-id>ai-glasses</d:tag-id>
    </d:device>

    <d:device>
        <d:name>XR Glasses</d:name>
        <d:id>xr_glasses_device</d:id>
        <d:manufacturer>Google</d:manufacturer>
        <d:playstore-enabled>true</d:playstore-enabled>
        <d:hardware>
            <d:screen>
                <d:screen-size>normal</d:screen-size>
                <d:diagonal-length>6.0</d:diagonal-length>
                <d:pixel-density>xhdpi</d:pixel-density>
                <d:screen-ratio>notlong</d:screen-ratio>
                <d:dimensions>
                    <d:x-dimension>1920</d:x-dimension>
                    <d:y-dimension>1200</d:y-dimension>
                </d:dimensions>
                <d:xdpi>240</d:xdpi>
                <d:ydpi>240</d:ydpi>
                <d:touch>
                    <d:multitouch>jazz-hands</d:multitouch>
                    <d:mechanism>finger</d:mechanism>
                    <d:screen-type>notouch</d:screen-type>
                </d:touch>
            </d:screen>
            <d:networking>
                Wifi
                Bluetooth
                NFC
            </d:networking>
            <d:sensors>
                Accelerometer
                Barometer
                Compass
                GPS
                Gyroscope
                LightSensor
                ProximitySensor
                StepCounter
                StepDetector
            </d:sensors>
            <d:mic>true</d:mic>
            <d:camera>
                <d:location>front</d:location>
                <d:autofocus>false</d:autofocus>
                <d:flash>false</d:flash>
            </d:camera>
            <d:keyboard>qwerty</d:keyboard>
            <d:nav>trackball</d:nav>
            <d:ram unit="GiB">4</d:ram>
            <d:buttons>soft</d:buttons>
            <d:internal-storage unit="GiB">10</d:internal-storage>
            <d:removable-storage unit="MiB">0</d:removable-storage>
            <d:cpu>Generic CPU</d:cpu>
            <d:gpu>Generic GPU</d:gpu>
            <d:abi>
                armeabi
                armeabi-v7a
                arm64-v8a
                x86
                x86_64
                mips
                mips64
            </d:abi>
            <d:dock> </d:dock>
            <d:power-type>battery</d:power-type>
        </d:hardware>
        <d:software>
            <d:api-level>34</d:api-level>
            <d:live-wallpaper-support>true</d:live-wallpaper-support>
            <d:bluetooth-profiles> </d:bluetooth-profiles>
            <d:gl-version>3.2</d:gl-version>
            <d:gl-extensions/>
            <d:status-bar>true</d:status-bar>
        </d:software>
        <d:state name="Landscape" default="true">
            <d:description>The device in landscape view</d:description>
            <d:screen-orientation>land</d:screen-orientation>
            <d:keyboard-state>keyshidden</d:keyboard-state>
            <d:nav-state>nonav</d:nav-state>
        </d:state>
        <d:tag-id>android-xr</d:tag-id>
        <d:boot-props>
            <d:boot-prop>
                <d:prop-name>emulator.dev.xr.left_fov</d:prop-name>
                <d:prop-value>0.5236,0.5236,0.2618,0.3491</d:prop-value>
            </d:boot-prop>
            <d:boot-prop>
                <d:prop-name>emulator.dev.xr.mm_to_dp</d:prop-name>
                <d:prop-value>1.5</d:prop-value>
            </d:boot-prop>
            <d:boot-prop>
                <d:prop-name>emulator.dev.xr.dp_per_meter</d:prop-name>
                <d:prop-value>1200</d:prop-value>
            </d:boot-prop>
            <d:boot-prop>
                <d:prop-name>emulator.dev.xr.disp_modality</d:prop-name>
                <d:prop-value>ost</d:prop-value>
            </d:boot-prop>
        </d:boot-props>
    </d:device>
</d:devices>
