#include <stdio.h>

// This data will go into the 4KB-aligned segment
const char* my_string = "Hello, 4KB-aligned data!";

// This code will go into the 16KB-aligned segment
void my_func() {
    if (my_string) {
        // Just some code to ensure the .text section isn't empty
    }
}
