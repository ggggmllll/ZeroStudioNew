<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_light_background"
    android:fitsSystemWindows="true">

    <!-- Material 3 顶部应用栏 -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="@color/md_theme_light_surface">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            app:expandedTitleMarginStart="24dp"
            app:expandedTitleMarginBottom="24dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/md_theme_light_surface"
            app:titleCollapseMode="scale"
            style="@style/Widget.Material3.CollapsingToolbar.Medium">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/topAppBar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:title="MCP Server"
                app:layout_collapseMode="pin" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- 可滚动内容区域 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">

            <!-- 状态概览 (3列卡片) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="24dp">

                <!-- 状态卡片 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStatus"
                    style="@style/Widget.App.Card.Filled.Tonal"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/md_theme_light_secondaryContainer">
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">
                        
                        <!-- 复用 ic_run (如果合适) 或使用新建的 ic_mcp_status_dot -->
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_mcp_status_dot" 
                            app:tint="@color/md_theme_light_primary"
                            tools:ignore="ContentDescription" />
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status"
                            android:layout_marginTop="8dp"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="@color/md_theme_light_onSurfaceVariant"/>

                        <TextView
                            android:id="@+id/statusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active"
                            android:textStyle="bold"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="@color/md_theme_light_onSurface"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 端口卡片 -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.App.Card.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    app:strokeColor="@color/md_theme_light_outline">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <!-- 复用 ic_target_positioning_24dp 作为端口图标 -->
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_target_positioning_24dp"
                            app:tint="@color/md_theme_light_secondary"
                            tools:ignore="ContentDescription"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Port"
                            android:layout_marginTop="8dp"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="@color/md_theme_light_onSurfaceVariant"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8080"
                            android:textStyle="bold"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="@color/md_theme_light_onSurface"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 请求计数卡片 -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.App.Card.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:strokeColor="@color/md_theme_light_outline">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="12dp"
                        android:gravity="center">

                        <!-- 复用 ic_sync 作为请求图标 -->
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_sync"
                            app:tint="@color/md_theme_light_tertiary"
                            tools:ignore="ContentDescription"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Requests"
                            android:layout_marginTop="8dp"
                            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
                            android:textColor="@color/md_theme_light_onSurfaceVariant"/>

                        <TextView
                            android:id="@+id/requestCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textStyle="bold"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="@color/md_theme_light_onSurface"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 连接信息部分 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connection Endpoints"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/md_theme_light_onSurface"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card.Filled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/md_theme_light_surfaceVariant"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Localhost (使用新建的 ic_mcp_computer) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_mcp_computer"
                            app:tint="@color/md_theme_light_onSurfaceVariant"
                            tools:ignore="ContentDescription"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loopback (Local)"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="@color/md_theme_light_onSurfaceVariant"/>
                            <TextView
                                android:id="@+id/localUrl"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="http://127.0.0.1:8080/ZeroStudio"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="@color/md_theme_light_onSurface"
                                android:fontFamily="monospace"/>
                        </LinearLayout>

                        <!-- 复用 ic_copy -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/copyLocal"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:icon="@drawable/ic_copy"
                            app:iconTint="@color/md_theme_light_onSurfaceVariant" />
                    </LinearLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        app:dividerColor="@color/md_theme_light_outline"/>

                    <!-- WiFi (使用新建的 ic_mcp_wifi) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_mcp_wifi"
                            app:tint="@color/md_theme_light_onSurfaceVariant"
                            tools:ignore="ContentDescription"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Wi-Fi Network"
                                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                                android:textColor="@color/md_theme_light_onSurfaceVariant"/>
                            <TextView
                                android:id="@+id/wifiUrl"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Unavailable"
                                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                                android:textColor="@color/md_theme_light_onSurface"
                                android:fontFamily="monospace"/>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/copyWifi"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:icon="@drawable/ic_copy"
                            app:iconTint="@color/md_theme_light_onSurfaceVariant" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 工作区设置 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Workspace"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/md_theme_light_onSurface"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:strokeColor="@color/md_theme_light_outline"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <!-- 复用 ic_folder -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@color/md_theme_light_secondaryContainer"
                        android:padding="10dp"
                        android:src="@drawable/ic_folder"
                        app:tint="@color/md_theme_light_onSecondaryContainer"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Mcp.MediumComponent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp">
                        
                        <TextView
                            android:id="@+id/workspaceName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="mcp_workspace"
                            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                            android:textColor="@color/md_theme_light_onSurface"/>
                        
                        <TextView
                            android:id="@+id/workspacePath"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/storage/emulated/0/..."
                            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                            android:textColor="@color/md_theme_light_onSurfaceVariant"
                            android:ellipsize="middle"
                            android:singleLine="true"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/switchWorkspace"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change"
                        android:backgroundTint="@color/md_theme_light_secondaryContainer"
                        android:textColor="@color/md_theme_light_onSecondaryContainer"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 终端日志区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <!-- 复用 ic_terminal -->
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_terminal"
                    app:tint="@color/md_theme_light_onSurface"
                    android:layout_marginEnd="8dp"
                    tools:ignore="ContentDescription"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Live Terminal"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/md_theme_light_onSurface"/>
                
                <TextView
                    android:id="@+id/runtimeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:textColor="@color/md_theme_light_onSurfaceVariant"
                    android:fontFamily="monospace"
                    android:layout_marginEnd="12dp"/>

                <!-- 之前是 TextView (CLEAR)，现在改为 Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/clearLogs"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear"
                    android:textColor="@color/md_theme_light_primary"
                    android:minHeight="0dp"
                    android:paddingVertical="4dp"/>
            </LinearLayout>

            <!-- 终端卡片 (暗色风格) -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.App.Card.Filled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/terminal_background"
                app:contentPadding="0dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="350dp"
                    android:padding="12dp"
                    android:scrollbars="vertical"
                    android:fadeScrollbars="false"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB 按钮: 复用 ic_refresh 或 ic_run -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Restart"
        android:textColor="@color/md_theme_light_onPrimaryContainer"
        app:icon="@drawable/ic_refresh"
        app:iconTint="@color/md_theme_light_onPrimaryContainer"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:backgroundTint="@color/md_theme_light_primaryContainer"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>