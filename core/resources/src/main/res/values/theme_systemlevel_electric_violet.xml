     <color name="_electric_violet_light_colorOnPrimary">#ffffffff</color>
     <color name="_electric_violet_light_colorOnPrimaryContainer">#ff290056</color>
     <color name="_electric_violet_light_colorSecondary">#ff006494</color>
     <color name="_electric_violet_light_colorSecondaryContainer">#ffcae6ff</color>
     <color name="_electric_violet_light_colorOnSecondary">#ffffffff</color>
     <color name="_electric_violet_light_colorOnSecondaryContainer">#ff001e30</color>
     <color name="_electric_violet_light_colorError">#ffba1a1a</color>
