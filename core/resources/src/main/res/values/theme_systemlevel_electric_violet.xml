     <color name="_electric_violet_light_selection">#66eaddff</color>

     <style
          name="Theme.AndroidIDE.ElectricViolet"
          parent="Theme.AndroidIDE">
          <item name="colorPrimary">@color/_electric_violet_light_colorPrimary</item>
          <item name="colorPrimaryContainer">@color/_electric_violet_light_colorPrimaryContainer</item>
