          <item name="colorSecondary">@color/_electric_violet_light_colorSecondary</item>
          <item name="colorSecondaryContainer">@color/_electric_violet_light_colorSecondaryContainer</item>
          <item name="colorOnSecondary">@color/_electric_violet_light_colorOnSecondary</item>
          <item name="colorOnSecondaryContainer">@color/_electric_violet_light_colorOnSecondaryContainer</item>
          <item name="android:colorBackground">@color/_electric_violet_light_colorBackground</item>
