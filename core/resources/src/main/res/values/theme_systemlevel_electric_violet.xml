          <item name="android:textColorHighlight">@color/_electric_violet_light_selection</item>
          <item name="android:statusBarColor">@color/_electric_violet_light_colorBackground</item>
          <item name="android:navigationBarColor">@color/_electric_violet_light_colorBackground</item>
          <item name="android:windowLightStatusBar">true</item>

          <item name="terminalTextColor">@color/_electric_violet_light_colorOnBackground</item>
          <item name="terminalBackgroundColor">@color/_electric_violet_light_colorBackground</item>
          <item name="terminalCursorStyle">verticalBar</item>
     </style>

