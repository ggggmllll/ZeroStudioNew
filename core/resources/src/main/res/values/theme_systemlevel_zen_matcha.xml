  <color name="_zen_matcha_light_ripple">#33416916</color>
  <color name="_zen_matcha_light_selection">#66c1f190</color>

  <style name="Theme.AndroidIDE.ZenMatcha" parent="Theme.AndroidIDE">
    <item name="colorPrimary">@color/_zen_matcha_light_colorPrimary</item>
    <item name="colorPrimaryContainer">@color/_zen_matcha_light_colorPrimaryContainer</item>
    <item name="colorPrimaryDark">@color/_zen_matcha_light_colorPrimaryDark</item>
    <item name="colorPrimaryInverse">@color/_zen_matcha_light_colorPrimaryInverse</item>
    <item name="colorOnPrimary">@color/_zen_matcha_light_colorOnPrimary</item>
    <item name="colorOnPrimaryContainer">@color/_zen_matcha_light_colorOnPrimaryContainer</item>
    <item name="colorSecondary">@color/_zen_matcha_light_colorSecondary</item>
    <item name="colorSecondaryContainer">@color/_zen_matcha_light_colorSecondaryContainer</item>
    <item name="colorOnSecondary">@color/_zen_matcha_light_colorOnSecondary</item>
    <item name="colorOnSecondaryContainer">@color/_zen_matcha_light_colorOnSecondaryContainer</item>
    <item name="android:colorBackground">@color/_zen_matcha_light_colorBackground</item>
    <item name="colorOnBackground">@color/_zen_matcha_light_colorOnBackground</item>
    <item name="colorSurface">@color/_zen_matcha_light_colorSurface</item>
    <item name="colorOnSurface">@color/_zen_matcha_light_colorOnSurface</item>
    <item name="colorSurfaceVariant">@color/_zen_matcha_light_colorSurfaceVariant</item>
    <item name="colorOnSurfaceVariant">@color/_zen_matcha_light_colorOnSurfaceVariant</item>
    <item name="colorOutline">@color/_zen_matcha_light_colorOutline</item>
    
    <item name="colorControlHighlight">@color/_zen_matcha_light_ripple</item>
    <item name="android:colorControlHighlight">@color/_zen_matcha_light_ripple</item>
    <item name="android:textColorHighlight">@color/_zen_matcha_light_selection</item>
    <item name="android:statusBarColor">@color/_zen_matcha_light_colorBackground</item>
    <item name="android:navigationBarColor">@color/_zen_matcha_light_colorBackground</item>
    <item name="android:windowLightStatusBar">true</item>

    <item name="terminalTextColor">@color/_zen_matcha_light_colorOnBackground</item>
    <item name="terminalBackgroundColor">@color/_zen_matcha_light_colorBackground</item>
    <item name="terminalCursorStyle">underline</item>
  </style>

