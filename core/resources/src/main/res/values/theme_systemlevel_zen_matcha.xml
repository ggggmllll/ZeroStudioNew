  ~  Style: Calming Matcha Green 禅意抹茶 - 抹茶绿与玄米色
  -设计理念：
白昼：清新的抹茶绿，搭配米黄色的纸张感背景，阅读护眼。
黑夜：深邃的森林绿，降低了对比度，减少眼部疲劳。
全局覆盖：使用了更柔和的选中颜色。
  -->
<resources>
  <!-- Light -->
  <color name="_zen_matcha_light_colorPrimary">#ff416916</color>
  <color name="_zen_matcha_light_colorPrimaryContainer">#ffc1f190</color>
  <color name="_zen_matcha_light_colorPrimaryDark">#ffffffff</color>
  <color name="_zen_matcha_light_colorPrimaryInverse">#ffa6d577</color>
  <color name="_zen_matcha_light_colorOnPrimary">#ffffffff</color>
  <color name="_zen_matcha_light_colorOnPrimaryContainer">#ff0e2000</color>
  <color name="_zen_matcha_light_colorSecondary">#ff586249</color>
  <color name="_zen_matcha_light_colorSecondaryContainer">#ffdce7c7</color>
  <color name="_zen_matcha_light_colorOnSecondary">#ffffffff</color>
  <color name="_zen_matcha_light_colorOnSecondaryContainer">#ff161e0b</color>
  <color name="_zen_matcha_light_colorError">#ffba1a1a</color>
  <color name="_zen_matcha_light_colorBackground">#fffdfcf5</color> <!-- Rice Paper -->
  <color name="_zen_matcha_light_colorOnBackground">#ff1b1c18</color>
  <color name="_zen_matcha_light_colorSurface">#fffdfcf5</color>
