  <color name="_golden_hour_dark_colorError">#ffffb4ab</color>
  <color name="_golden_hour_dark_colorBackground">#ff1f1b16</color> <!-- Deep Bronze Black -->
  <color name="_golden_hour_dark_colorOnBackground">#ffeae1d9</color>
  <color name="_golden_hour_dark_colorSurface">#ff1f1b16</color>
  <color name="_golden_hour_dark_colorOnSurface">#ffeae1d9</color>
