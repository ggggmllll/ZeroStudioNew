  <color name="_golden_hour_dark_colorOnSecondary">#ff3b2e15</color>
  <color name="_golden_hour_dark_colorOnSecondaryContainer">#fff7dfbb</color>
  <color name="_golden_hour_dark_colorTertiary">#ffb3cea8</color>
  <color name="_golden_hour_dark_colorTertiaryContainer">#ff364d36</color>
  <color name="_golden_hour_dark_colorOnTertiary">#ff20361b</color>
