    <item name="colorSecondaryContainer">@color/_golden_hour_dark_colorSecondaryContainer</item>
    <item name="colorOnSecondaryContainer">@color/_golden_hour_dark_colorOnSecondaryContainer</item>
    <item name="android:colorBackground">@color/_golden_hour_dark_colorBackground</item>
    <item name="colorOnBackground">@color/_golden_hour_dark_colorOnBackground</item>
    <item name="colorSurface">@color/_golden_hour_dark_colorSurface</item>
    <item name="colorOnSurface">@color/_golden_hour_dark_colorOnSurface</item>
    <item name="colorSurfaceVariant">@color/_golden_hour_dark_colorSurfaceVariant</item>
    <item name="colorOnSurfaceVariant">@color/_golden_hour_dark_colorOnSurfaceVariant</item>
    <item name="colorOutline">@color/_golden_hour_dark_colorOutline</item>
    <item name="colorOnSurfaceInverse">@color/_golden_hour_dark_colorOnSurfaceInverse</item>
    <item name="colorSurfaceInverse">@color/_golden_hour_dark_colorSurfaceInverse</item>
    <item name="colorPrimaryInverse">@color/_golden_hour_dark_colorPrimaryInverse</item>

    <!-- Global UI Coverage Dark -->
    <item name="colorControlHighlight">@color/_golden_hour_dark_ripple</item>
    <item name="android:colorControlHighlight">@color/_golden_hour_dark_ripple</item>
    <item name="android:textColorHighlight">@color/_golden_hour_dark_selection</item>
    <item name="android:statusBarColor">@color/_golden_hour_dark_colorBackground</item>
    <item name="android:navigationBarColor">@color/_golden_hour_dark_colorBackground</item>
    <item name="android:windowLightStatusBar">false</item>
    
    <item name="terminalTextColor">@color/_golden_hour_dark_colorOnBackground</item>
    <item name="terminalBackgroundColor">@color/_golden_hour_dark_colorBackground</item>
    <item name="terminalCursorStyle">block</item>
  </style>
