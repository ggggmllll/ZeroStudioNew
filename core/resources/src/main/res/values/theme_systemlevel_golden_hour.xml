  <color name="_golden_hour_dark_colorSurfaceInverse">#ffeae1d9</color>
  <color name="_golden_hour_dark_colorPrimaryInverse">#ff7a5900</color>
  <color name="_golden_hour_dark_ripple">#44fddc76</color>
  <color name="_golden_hour_dark_selection">#665d4200</color>

  <style name="Theme.AndroidIDE.GoldenHour.Dark" parent="Theme.AndroidIDE.GoldenHour">
    <item name="colorPrimary">@color/_golden_hour_dark_colorPrimary</item>
    <item name="colorPrimaryDark">@color/_golden_hour_dark_colorPrimaryDark</item>
