<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingEnd="8dp"
    android:paddingVertical="6dp"
    android:minHeight="40dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground"> <!-- 必须使用 match_parent 和 ripple 背景 -->

    <ViewFlipper
        android:id="@+id/chevronLoadingSwitcher"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginEnd="6dp">

        <ImageView
            android:id="@+id/filetree_chevron"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="?attr/colorOnSurfaceVariant" />

        <ProgressBar
            android:id="@+id/loading_progress"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:indeterminateTint="?attr/colorPrimary" />

    </ViewFlipper>

    <ImageView
        android:id="@+id/filetree_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="10dp"
        tools:src="@drawable/ic_language_java" />

    <TextView
        android:id="@+id/filetree_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textColor="?attr/colorOnSurface"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="MainActivity.kt" />

</LinearLayout>