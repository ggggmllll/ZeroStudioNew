<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="180dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp">

        <!-- 顶部搜索框 (使用 TextInputLayout 或自定义背景) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="33dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="8dp">
            
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_git_input_rounded"
                android:backgroundTint="?attr/colorSurfaceVariant"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search_24"
                    app:tint="?attr/colorOnSurfaceVariant"/>

                <EditText
                    android:id="@+id/et_search_branch"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Filter branches..."
                    android:textColor="?attr/colorOnSurface"
                    android:textColorHint="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:singleLine="true"
                    android:imeOptions="actionSearch"
                    android:paddingStart="8dp"/>
            </LinearLayout>
        </FrameLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.8dp"
            android:background="?attr/colorPrimary"
            android:alpha="0.2"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_branch_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="350dp" 
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            tools:listitem="@layout/item_git_branch_popup"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorPrimary"
            android:alpha="0.2"/>

        <!-- 底部按钮 -->
        <TextView
            android:id="@+id/btn_new_branch"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="?selectableItemBackground"
            android:gravity="center"
            android:text="+ New Branch"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>