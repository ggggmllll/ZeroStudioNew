<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_width="match_parent"
     android:layout_height="match_parent"
     android:orientation="vertical"
     android:background="?attr/colorSurface">

     <include layout="@layout/layout_git_mini_toolbar" />

     <androidx.cardview.widget.CardView
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:layout_margin="12dp"
          app:cardBackgroundColor="?attr/colorOnSurfaceVariant"
          app:cardCornerRadius="8dp"
          app:cardElevation="0dp">

          <LinearLayout
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:orientation="vertical"
               android:padding="12dp">

               <EditText
                    android:id="@+id/et_commit_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/colorSurface"
                    android:hint="@string/input_your_commit_message"
                    android:textColor="?attr/colorOnSecondary"
                    android:textColorHint="?attr/colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:minLines="3"
                    android:gravity="top|start" />

               <CheckBox
                    android:id="@+id/cb_amend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/amend"
                    android:textColor="?attr/colorOnSurface"
                    android:buttonTint="?attr/colorSecondary"
                    android:layout_marginTop="8dp" />
          </LinearLayout>
     </androidx.cardview.widget.CardView>

     <androidx.recyclerview.widget.RecyclerView
          android:id="@+id/rv_changes"
          android:layout_width="match_parent"
          android:layout_height="0dp"
          android:layout_weight="1"
          android:clipToPadding="false" />

</LinearLayout>